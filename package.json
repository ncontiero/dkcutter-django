{
  "name": "dkcutter-django",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "DKCutter Django is a robust template for jumpstarting production-ready Django projects quickly with modern tooling.",
  "author": "Nicolas Contiero <https://github.com/ncontiero>",
  "license": "MIT",
  "scripts": {
    "typecheck": "bun --bun tsc --noEmit",
    "generate": "dkcutter .",
    "lint": "bun --bun eslint . -c eslint.config.ts",
    "lint:fix": "bun run lint --fix",
    "check": "bun run lint && bun run typecheck",
    "test": "bun --bun vitest run",
    "test:typecheck": "RUN_TYPE_CHECK=true bun run test",
    "test:strict-eslint": "GET_WARNINGS=true bun run test"
  },
  "devDependencies": {
    "@clack/prompts": "1.7.0",
    "@ncontiero/eslint-config": "8.3.3",
    "@types/bun": "1.3.14",
    "ansis": "4.3.1",
    "colorette": "2.0.20",
    "dkcutter": "6.2.0",
    "eslint": "10.7.0",
    "tinyexec": "1.2.4",
    "tinyglobby": "0.2.17",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "zod": "4.4.3"
  }
}
