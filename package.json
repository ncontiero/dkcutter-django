{
  "name": "dkcutter-django",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "DKCutter Django is a framework for jumpstarting production-ready Django projects quickly.",
  "author": "Nicolas Contiero <https://github.com/ncontiero>",
  "license": "MIT",
  "scripts": {
    "typecheck": "bun --bun tsc --noEmit",
    "generate": "dkcutter .",
    "lint": "bun --bun eslint . -c eslint.config.ts",
    "lint:fix": "bun run lint --fix",
    "check": "bun run lint && bun run typecheck",
    "test": "bun --bun vitest run",
    "test:strict": "GET_WARNINGS=true bun run test"
  },
  "devDependencies": {
    "@ncontiero/eslint-config": "8.2.1",
    "@types/bun": "1.3.14",
    "@types/prompts": "2.4.9",
    "colorette": "2.0.20",
    "dkcutter": "6.0.0",
    "eslint": "10.4.1",
    "prompts": "2.4.2",
    "tinyexec": "1.2.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "zod": "4.4.3"
  }
}
