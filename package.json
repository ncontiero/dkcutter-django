{
  "name": "dkcutter-django",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "DKCutter Django is a framework for jumpstarting production-ready Django projects quickly.",
  "author": "Nicolas Contiero <https://github.com/ncontiero>",
  "license": "MIT",
  "scripts": {
    "typecheck": "bun --bun tsc --noEmit",
    "generate": "dkcutter .",
    "lint": "bun --bun eslint . -c eslint.config.ts",
    "lint:fix": "bun run lint --fix",
    "check": "bun run lint && bun run typecheck",
    "test": "bun --bun vitest run",
    "test:strict": "GET_WARNINGS=true bun run test"
  },
  "devDependencies": {
    "@ncontiero/eslint-config": "8.2.1",
    "@rspack/cli": "^2.0.6",
    "@rspack/core": "^2.0.6",
    "@types/bun": "1.3.14",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.16",
    "clsx": "^2.1.1",
    "colorette": "^2.0.20",
    "dkcutter": "6.0.0",
    "eslint": "^10.4.1",
    "fast-glob": "^3.3.3",
    "prompts": "^2.4.2",
    "react": "^19.2.7",
    "react-email": "6.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tinyexec": "^1.2.4",
    "tsx": "^4.22.4",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  }
}
