{
  "name": "dkcutter-django",
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "description": "DKCutter Django is a framework for jumpstarting production-ready Django projects quickly.",
  "author": "Nicolas Contiero <https://github.com/ncontiero>",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate": "dkcutter .",
    "lint": "eslint . -c eslint.config.js",
    "lint:fix": "pnpm lint --fix",
    "check": "pnpm lint && pnpm typecheck",
    "test": "vitest run",
    "test:strict": "GET_WARNINGS=true pnpm test"
  },
  "dependencies": {
    "dkcutter": "5.0.7"
  },
  "devDependencies": {
    "@ncontiero/eslint-config": "8.2.1",
    "@rspack/cli": "^2.0.5",
    "@rspack/core": "^2.0.5",
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.15",
    "clsx": "^2.1.1",
    "colorette": "^2.0.20",
    "eslint": "^10.4.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "ora": "^9.4.0",
    "prompts": "^2.4.2",
    "react": "^19.2.6",
    "react-email": "6.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  }
}
